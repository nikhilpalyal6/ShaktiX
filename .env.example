# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Enable the following APIs:
# - Maps JavaScript API
# - Places API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Configuration (if needed)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# OpenAI API Key for Chatbot
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (alternative to OpenAI)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Infermedica API for AI Symptom Checker
# Get your API credentials from: https://developer.infermedica.com/
# Sign up for a free account to get App ID and API Key
# This enables real medical diagnosis instead of demo mode
INFERMEDICA_APP_ID=your_infermedica_app_id_here
INFERMEDICA_API_KEY=your_infermedica_api_key_here

# Other API keys as needed